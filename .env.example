# Database
DATABASE_URL=postgresql+asyncpg://aidms:changeme@localhost:5432/aidms
POSTGRES_PASSWORD=changeme

# Redis
REDIS_URL=redis://localhost:6379

# MinIO
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=documents
MINIO_SECURE=false

# Google Cloud Vision
GOOGLE_CLOUD_CREDENTIALS=/path/to/service-account.json
GOOGLE_CLOUD_PROJECT=your-project-id

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# JWT
JWT_SECRET=change-me-to-a-long-random-string-in-production
JWT_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_DAYS=7

# App
CORS_ORIGINS=http://localhost:3000
ENVIRONMENT=development
LOG_LEVEL=INFO
MAX_UPLOAD_SIZE_MB=50

# SMTP — used to deliver email-OTP verification codes on /auth/register.
# If SMTP_HOST is left empty, the API logs the OTP at INFO instead of sending mail.
# SMTP_SECURE=true with port 465 → implicit SSL.
# SMTP_SECURE=false with port 587 → STARTTLS.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@docarchive.local
SMTP_FROM_NAME=DocArchive

# OTP
OTP_TTL_MINUTES=15
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_ATTEMPTS=5

# Frontend (linked from email body)
FRONTEND_BASE_URL=http://localhost:3000
